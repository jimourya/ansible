pipeline {
  agent { label 'linux' }
  environment {
   ANSIBLE_PRIVATE_KEY=credentials('jboss-private-key') 
  }
  stages {
    stage('Hello') {
      steps {
        sh 'ansible-galaxy collection install -r requirements.yml'
        sh 'ansible-playbook -i inventory/jboss.hosts --private-key=$ANSIBLE_PRIVATE_KEY wildfly/playbooks/playbook.yml'
      }
    }
  }
}
